# PySIP Configuration
# Copy this file to .env and fill in your SIP credentials
# Or use CLI arguments: python examples/basic_call.py --help

# Required: SIP Account Credentials
SIP_USERNAME=your_extension
SIP_PASSWORD=your_password
SIP_SERVER=sip.example.com

# Optional: SIP port (default: 5060)
SIP_PORT=5060

# Optional: Default destination for outbound call examples
TEST_NUMBER=1234567890

# Optional: Local IP (auto-detected if not set)
# LOCAL_IP=192.168.1.100

# Optional: TTS voice (default: en-US-AriaNeural)
# TTS_VOICE=en-US-GuyNeural
